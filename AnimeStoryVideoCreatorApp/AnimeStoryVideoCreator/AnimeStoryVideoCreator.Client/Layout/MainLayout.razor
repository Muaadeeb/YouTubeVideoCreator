@inherits LayoutComponentBase

<div class="min-h-screen bg-[#0F1117] text-[#E5E7EB] flex">
    <!-- Sidebar -->
    <div class="w-72 bg-zinc-950 border-r border-zinc-800 p-6 flex flex-col">
        <h1 class="text-3xl font-bold neon-cyan mb-8">Anime Story Creator</h1>
        
        <nav class="flex-1 space-y-2">
            <a href="/" class="block px-4 py-3 rounded-xl bg-zinc-900 hover:bg-zinc-800 transition-colors neon-cyan">New Project</a>
            <a href="/projects" class="block px-4 py-3 rounded-xl hover:bg-zinc-900 transition-colors">My Projects</a>
            <a href="/characters" class="block px-4 py-3 rounded-xl hover:bg-zinc-900 transition-colors">Character Vault</a>
            <a href="/series-settings" class="block px-4 py-3 rounded-xl hover:bg-zinc-900 transition-colors">Series Settings</a>
            <a href="/scripts" class="block px-4 py-3 rounded-xl hover:bg-zinc-900 transition-colors">Script Library</a>
            <a href="/storyboards" class="block px-4 py-3 rounded-xl hover:bg-zinc-900 transition-colors">Storyboard Gallery</a>
            <a href="/analytics" class="block px-4 py-3 rounded-xl hover:bg-zinc-900 transition-colors">Analytics</a>
            <a href="/settings" class="block px-4 py-3 rounded-xl hover:bg-zinc-900 transition-colors">Settings</a>
        </nav>
    </div>

    <!-- Main Content -->
    <div class="flex-1 p-10">
        <h2 class="text-2xl mb-6">@Title</h2>
        @Body
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Dashboard";
}