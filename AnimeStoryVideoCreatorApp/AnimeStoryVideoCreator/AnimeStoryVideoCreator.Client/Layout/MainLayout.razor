@inherits LayoutComponentBase

<div style="min-height: 100vh; background-color: #0F1117; color: #E5E7EB; display: flex; font-family: system-ui, sans-serif;">

    <!-- Sidebar -->
    <div style="width: 280px; background-color: #1A1F2E; border-right: 1px solid #334155; padding: 24px; display: flex; flex-direction: column;">
        
        <div style="margin-bottom: 40px;">
            <h1 style="color: #00F5FF; font-size: 28px; font-weight: bold; margin: 0;">Anime Story Creator</h1>
            <p style="color: #64748B; font-size: 14px; margin-top: 4px;">YouTube Video Factory</p>
        </div>

        <nav style="flex: 1; display: flex; flex-direction: column; gap: 8px;">
            <a href="/" style="padding: 14px 20px; background-color: #334155; color: #00F5FF; border-radius: 12px; text-decoration: none; font-weight: 500;">✨ New Project</a>
            <a href="/projects" style="padding: 14px 20px; border-radius: 12px; text-decoration: none; color: #E5E7EB;">📁 My Projects</a>
            <a href="/characters" style="padding: 14px 20px; border-radius: 12px; text-decoration: none; color: #E5E7EB;">👤 Character Vault</a>
            <a href="/series-settings" style="padding: 14px 20px; border-radius: 12px; text-decoration: none; color: #E5E7EB;">📚 Series Settings</a>
            <a href="/scripts" style="padding: 14px 20px; border-radius: 12px; text-decoration: none; color: #E5E7EB;">📜 Script Library</a>
            <a href="/storyboards" style="padding: 14px 20px; border-radius: 12px; text-decoration: none; color: #E5E7EB;">🎞️ Storyboard Gallery</a>
            <a href="/analytics" style="padding: 14px 20px; border-radius: 12px; text-decoration: none; color: #E5E7EB;">📊 Analytics</a>
            <a href="/settings" style="padding: 14px 20px; border-radius: 12px; text-decoration: none; color: #E5E7EB;">⚙️ Settings</a>
        </nav>

        <div style="margin-top: auto; padding-top: 24px; border-top: 1px solid #334155; color: #64748B; font-size: 13px; text-align: center;">
            Powered by Grok Imagine
        </div>
    </div>

    <!-- Main Content -->
    <div style="flex: 1; display: flex; flex-direction: column;">
        <header style="height: 64px; background-color: #1A1F2E; border-bottom: 1px solid #334155; display: flex; align-items: center; padding: 0 32px;">
            <h2 style="margin: 0; font-size: 20px; font-weight: 600;">@Title</h2>
        </header>
        
        <main style="flex: 1; padding: 40px; overflow: auto;">
            @Body
        </main>
    </div>
</div>

@code {
    [Parameter] public string Title { get; set; } = "Dashboard";
}