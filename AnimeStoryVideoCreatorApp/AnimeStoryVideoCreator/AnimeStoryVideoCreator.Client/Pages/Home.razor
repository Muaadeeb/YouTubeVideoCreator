@code {
    private bool showModal = false;

    private string newProjectName = "";
    private string newSeriesName = "";
    private string newTargetLength = "15-30";
    private string newArtStyle = "Classic";

    private void ShowNewProjectModal()
    {
        showModal = true;
        newProjectName = "";
        newSeriesName = "";
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task CreateProject()
    {
        if (string.IsNullOrWhiteSpace(newProjectName))
        {
            await JS.InvokeVoidAsync("alert", "Please enter a Project Name.");
            return;
        }

        // Success message
        await JS.InvokeVoidAsync("alert",
            $"✅ Project Created Successfully!\n\n" +
            $"Project Name: {newProjectName}\n" +
            $"Series: {newSeriesName}\n" +
            $"Length: {newTargetLength}\n" +
            $"Art Style: {newArtStyle}\n\n" +
            "Next step: Story Input screen will open here.");

        showModal = false;

        // TODO: In the next step, we will save this project and navigate to the Story Input screen
    }
}