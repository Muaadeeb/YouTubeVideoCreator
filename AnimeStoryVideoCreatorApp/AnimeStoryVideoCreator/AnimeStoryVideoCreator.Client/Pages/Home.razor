@* @page "/"
@inject IJSRuntime JS

<div class="max-w-4xl">
    <h1 style="color: #00F5FF; font-size: 32px; margin-bottom: 8px;">Welcome to Anime Story Creator</h1>
    <p style="color: #CBD5E1; font-size: 18px;">This is your personal YouTube video factory for original anime / manhwa-style stories.</p>

    <div style="margin-top: 48px; padding: 32px; background-color: #1E2937; border-radius: 16px;">
        <h2 style="color: #E2E8F0; margin-bottom: 24px;">Quick Start</h2>
        
        <button @onclick="ShowNewProjectModal"
                style="background-color: #00F5FF; color: #0F1117; padding: 16px 32px; border: none; border-radius: 12px; font-size: 18px; font-weight: 600; cursor: pointer;">
            ✨ Create New Project
        </button>
        
        <p style="margin-top: 24px; color: #94A3B8;">
            This will open the New Project form as defined in our spec.
        </p>
    </div>
</div>

<!-- New Project Modal -->
@if (showModal)
{
    <div style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.85); display: flex; align-items: center; justify-content: center; z-index: 1000;">
        <div style="background-color: #1E2937; width: 520px; border-radius: 16px; padding: 32px; box-shadow: 0 20px 60px rgba(0,0,0,0.6);">
            
            <h2 style="color: #00F5FF; margin-bottom: 24px; font-size: 24px;">Create New Project</h2>
            
            <div style="margin-bottom: 20px;">
                <label style="display: block; color: #94A3B8; margin-bottom: 6px; font-size: 14px;">Project Name</label>
                <input @bind="newProjectName"
                       style="width: 100%; padding: 14px; background-color: #334155; border: none; border-radius: 8px; color: white; font-size: 16px;"
                       placeholder="Episode 1 - The Goblin Lord Awakens" />
            </div>

            <div style="margin-bottom: 20px;">
                <label style="display: block; color: #94A3B8; margin-bottom: 6px; font-size: 14px;">YouTube Series Name</label>
                <input @bind="newSeriesName"
                       style="width: 100%; padding: 14px; background-color: #334155; border: none; border-radius: 8px; color: white; font-size: 16px;"
                       placeholder="Isekai System Chronicles" />
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 28px;">
                <div>
                    <label style="display: block; color: #94A3B8; margin-bottom: 6px; font-size: 14px;">Target Video Length</label>
                    <select @bind="newTargetLength"
                            style="width: 100%; padding: 14px; background-color: #334155; border: none; border-radius: 8px; color: white; font-size: 16px;">
                        <option value="Short">YouTube Short</option>
                        <option value="5-10">5-10 minutes</option>
                        <option value="15-30">15-30 minutes</option>
                        <option value="30-60">30-60+ minutes</option>
                    </select>
                </div>

                <div>
                    <label style="display: block; color: #94A3B8; margin-bottom: 6px; font-size: 14px;">Art Style</label>
                    <select @bind="newArtStyle"
                            style="width: 100%; padding: 14px; background-color: #334155; border: none; border-radius: 8px; color: white; font-size: 16px;">
                        <option value="Classic">Classic Manhwa</option>
                        <option value="Dark">Dark Anime</option>
                        <option value="Vibrant">Vibrant Comic Strip</option>
                        <option value="Mono">Monochrome Manga</option>
                    </select>
                </div>
            </div>

            <div style="display: flex; gap: 12px; justify-content: flex-end;">
                <button @onclick="CloseModal"
                        style="padding: 12px 28px; background-color: #334155; border: none; border-radius: 8px; color: white; cursor: pointer;">
                    Cancel
                </button>
                <button @onclick="CreateProject"
                        style="padding: 12px 32px; background-color: #00F5FF; color: #0F1117; border: none; border-radius: 8px; font-weight: 600; cursor: pointer;">
                    Create Project
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool showModal = false;

    private string newProjectName = "";
    private string newSeriesName = "";
    private string newTargetLength = "15-30";
    private string newArtStyle = "Classic";

    private void ShowNewProjectModal()
    {
        showModal = true;
        newProjectName = "";
        newSeriesName = "";
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private void CreateProject()
    {
        if (string.IsNullOrWhiteSpace(newProjectName))
        {
            JS.InvokeVoidAsync("alert", "Please enter a Project Name.");
            return;
        }

        // For now, show success message
        JS.InvokeVoidAsync("alert",
            $"Project Created Successfully!\n\n" +
            $"Project: {newProjectName}\n" +
            $"Series: {newSeriesName}\n" +
            $"Length: {newTargetLength}\n" +
            $"Style: {newArtStyle}");

        showModal = false;

        // TODO: Later we will save the project and navigate to Story Input screen
    }
} *@


